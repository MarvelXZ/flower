# =============================================================================
# Flower Production Environment Variables
# =============================================================================
# Copy to .env and fill in all values before deploying.
# The application will fail-closed on startup if required variables are missing.

# ---------------------------------------------------------------------------
# Django Core — REQUIRED
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=<generate-with-openssl-rand-hex-64>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=flower.example.com,api.flower.example.com
DJANGO_SETTINGS_MODULE=config.settings.production

# ---------------------------------------------------------------------------
# Database — REQUIRED
# ---------------------------------------------------------------------------
POSTGRES_DB=flower
POSTGRES_USER=flower
POSTGRES_PASSWORD=<strong-database-password>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECT_TIMEOUT=5

# ---------------------------------------------------------------------------
# Redis / Celery — REQUIRED
# ---------------------------------------------------------------------------
REDIS_URL=redis://:<redis-password>@redis:6379/0
CELERY_BROKER_URL=redis://:<redis-password>@redis:6379/0
CELERY_RESULT_BACKEND=redis://:<redis-password>@redis:6379/1

# ---------------------------------------------------------------------------
# MQTT Broker — REQUIRED for IoT
# ---------------------------------------------------------------------------
MQTT_HOST=mqtt
MQTT_PORT=1883

# ---------------------------------------------------------------------------
# B2B Security — REQUIRED for production
# ---------------------------------------------------------------------------
# Set to False in production — keys are stored in the tenant schema registry.
B2B_USE_SETTINGS_KEY=False

# Test API key — DISABLE in production.
# B2B_TEST_API_KEY=

# HMAC max clock skew (seconds).
B2B_HMAC_MAX_SKEW_SECONDS=300

# HTTP timeout for outbound provider delivery (seconds).
B2B_HTTP_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# CORS & CSRF — REQUIRED
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://flower.example.com
CSRF_TRUSTED_ORIGINS=https://flower.example.com,https://api.flower.example.com

# ---------------------------------------------------------------------------
# Sentry — RECOMMENDED
# ---------------------------------------------------------------------------
SENTRY_DSN=https://<key>@sentry.example.com/<project>

# ---------------------------------------------------------------------------
# Prometheus — RECOMMENDED
# ---------------------------------------------------------------------------
PROMETHEUS_METRICS_ENABLED=True

# ---------------------------------------------------------------------------
# Email — REQUIRED for notifications
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=notifications@flower.example.com
EMAIL_HOST_PASSWORD=<email-password>
DEFAULT_FROM_EMAIL=Flower <notifications@flower.example.com>

# ---------------------------------------------------------------------------
# Stripe — REQUIRED for billing
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Geo — optional
# ---------------------------------------------------------------------------
DJANGO_GIS_ENABLED=False
