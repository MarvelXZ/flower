# =============================================================================
# PlantOps SaaS — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=change-me-in-production-use-a-secure-random-string-of-at-least-50-characters
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_DB=plantops
POSTGRES_USER=plantops
POSTGRES_PASSWORD=plantops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://plantops:plantops@postgres:5432/plantops

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# RabbitMQ (Celery Broker)
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=plantops
RABBITMQ_DEFAULT_PASS=plantops
RABBITMQ_DEFAULT_VHOST=/
CELERY_BROKER_URL=amqp://plantops:plantops@rabbitmq:5672//

# ---------------------------------------------------------------------------
# Celery Result Backend
# ---------------------------------------------------------------------------
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------------------------------------------------------------------------
# CORS (for local frontend development)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Email (placeholder)
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@plantops.local

# ---------------------------------------------------------------------------
# Sentry / Observability (optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
